[Rule]
# 当配置文件中没有任何有效策略组时，Loon将使用内置的PROXY策略组
# 当配置文件中存在有效的策略组时，内置的PROXY策略组将不再允许被调用，仅可使用用户配置的策略组
# 配置文件已自带远程GEOIP, cn, DIRECT规则，请勿在此添加
# 请勿修改远程CN REGION规则的排序甚至删除
DOMAIN-SUFFIX,223789.xyz,DIRECT
DOMAIN-SUFFIX,289278.xyz,DIRECT
DOMAIN-SUFFIX,cn2gias.uk,Stream Media
DOMAIN-SUFFIX,sexemby.com,Stream Media
DOMAIN-SUFFIX,niceduck.lol,Stream Media
DOMAIN-SUFFIX,023168.xyz,Stream Media
IP-CIDR, 28.0.0.1/8, DIRECT
IP-CIDR, 198.18.0.1/16, DIRECT
IP-CIDR, 198.18.0.0/15, DIRECT
IP-CIDR6, fc00::/18, DIRECT
FINAL, 兜底后备策略

